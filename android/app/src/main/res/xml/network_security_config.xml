<?xml version="1.0" encoding="utf-8"?>
<!-- Android Network Security Configuration
     Allows plain HTTP to 10.0.2.2 ONLY (Android emulator loopback to host).
     All other traffic still requires HTTPS. -->
<network-security-config>
    <!-- Allow HTTP to the local Django dev server (emulator to host loopback) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>

    <!-- All other domains must use HTTPS -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
