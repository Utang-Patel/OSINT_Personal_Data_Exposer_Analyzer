# ============================================================
# .gitignore for osint_backend
# Prevents secrets, bytecode, and build artifacts from being
# committed to version control.
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so

# --- Virtual environments ---
venv/
.venv/
env/
ENV/

# --- Django ---
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
staticfiles/
media/

# --- Environment / secrets ---
# CRITICAL: never commit your real .env file!
.env

# --- Distribution / packaging ---
*.egg-info/
dist/
build/
.eggs/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- OS ---
.DS_Store
Thumbs.db
